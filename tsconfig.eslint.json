{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@/*": ["packages/client/src/*"],
      "@jsreview/shared": ["packages/shared/src/index.ts"],
      "@jsreview/shared/*": ["packages/shared/src/*"]
    },
    "types": ["bun", "node", "vite/client"]
  },
  "include": [
    "packages/client/api/**/*.ts",
    "packages/client/src/**/*",
    "packages/client/vite.config.ts",
    "packages/client/vite-plugins/**/*.ts",
    "packages/shared/scripts/**/*.ts",
    "packages/shared/src/**/*",
    "packages/shared/test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "packages/shared/src/problems/**/*",
    "packages/client/api/**/*.test.ts"
  ]
}
