{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "noEmit": false,
    "moduleResolution": "NodeNext",
    "module": "NodeNext"
  },
  "include": [
    "src/types.ts",
    "src/ai/**/*.ts",
    "src/util/**/*.ts",
    "src/runner/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
