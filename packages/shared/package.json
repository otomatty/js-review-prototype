{
  "name": "@jsreview/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": {
      "bun": "./src/types.ts",
      "node": "./dist/types.js",
      "default": "./src/types.ts"
    },
    "./assignments": "./src/assignments.ts",
    "./assignment-helpers": "./src/assignment-helpers.ts",
    "./curriculum/chapters": "./src/curriculum/chapters.ts",
    "./curriculum/stages": "./src/curriculum/stages.ts",
    "./grading/ast": "./src/grading/ast.ts",
    "./grading/evaluate": "./src/grading/evaluate.ts",
    "./runner/types": {
      "bun": "./src/runner/types.ts",
      "node": "./dist/runner/types.js",
      "default": "./src/runner/types.ts"
    },
    "./util/timeout": "./src/util/timeout.ts",
    "./util/validate-run-tests-request": {
      "bun": "./src/util/validate-run-tests-request.ts",
      "node": "./dist/util/validate-run-tests-request.js",
      "default": "./src/util/validate-run-tests-request.ts"
    },
    "./ai/types": {
      "bun": "./src/ai/types.ts",
      "node": "./dist/ai/types.js",
      "default": "./src/ai/types.ts"
    },
    "./ai/prompt": {
      "bun": "./src/ai/prompt.ts",
      "node": "./dist/ai/prompt.js",
      "default": "./src/ai/prompt.ts"
    },
    "./ai/validate-chat-request": {
      "bun": "./src/ai/validate-chat-request.ts",
      "node": "./dist/ai/validate-chat-request.js",
      "default": "./src/ai/validate-chat-request.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/problems.spec.ts",
    "check-integrity": "bun run scripts/check-integrity.ts",
    "scan-starter-comments": "bun run scripts/scan-starter-comments.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.5",
    "eslint-linter-browserify": "^9.1.0",
    "typescript": "^5.4.5"
  }
}
