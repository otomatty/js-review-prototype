{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "noEmit": true,
    "paths": {
      "@jsreview/shared": ["../shared/src/index.ts"],
      "@jsreview/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "vite.config.ts"]
}
