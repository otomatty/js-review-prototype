{
  "name": "js-review-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "JS自動コードレビューロジックのデモプロトタイプ (クライアント側Lint/AST + Vercel Edge + QuickJS テスト実行)",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @jsreview/client dev",
    "dev:client": "bun --filter @jsreview/client dev",
    "build:shared": "bun --filter @jsreview/shared build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun --filter @jsreview/shared test",
    "check-integrity": "bun --filter @jsreview/shared check-integrity"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@eslint/js": "9",
    "@types/bun": "^1.3.13",
    "@types/node": "22",
    "eslint": "9",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.2"
  },
  "engines": {
    "node": ">=22"
  }
}
